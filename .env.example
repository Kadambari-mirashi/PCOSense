# -----------------------------------------------------------------------------
# LLM backend (one of OpenAI, Ollama Cloud, or local Ollama)
# -----------------------------------------------------------------------------
# Provider selection priority:
#   1. OPENAI_API_KEY  set    → OpenAI         (gpt-4o-mini)
#   2. OLLAMA_API_KEY  set    → Ollama Cloud   (https://ollama.com)
#   3. neither set            → local Ollama   (http://localhost:11434)

# --- Option A: OpenAI (paid, requires credit) -------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Option B: Ollama Cloud (recommended for deployment) --------------------
# Get a key at https://ollama.com/settings/keys
# Free tier includes hosted gpt-oss:20b / 120b, Llama 3.x, Qwen, etc.
OLLAMA_API_KEY=
# Pick any cloud model — gpt-oss:120b is large + free, llama3.2 is faster.
# OLLAMA_MODEL=gpt-oss:120b

# --- Option C: Local Ollama (no API key, runs on localhost) -----------------
# Leave the two values above empty and ensure `ollama serve` is running.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# Optional persistence (Supabase)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_anon_or_service_role_key

# -----------------------------------------------------------------------------
# App networking
# -----------------------------------------------------------------------------
# Shiny frontend -> FastAPI base URL (no trailing slash).
# In single-service mode, this can stay localhost/PORT default.
#PCOSENSE_API_URL=http://127.0.0.1:8000

# Comma-separated browser origins for CORS (FastAPI).
# Set this to your deployed frontend origin(s).
# Example:
# CORS_ORIGINS=https://your-app.example.com,http://127.0.0.1:3838
#CORS_ORIGINS=https://connect.systems-apps.com


# Platform runtime port (used by hosted environments like Render/Connect).
PORT=8000
