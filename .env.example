# -----------------------------------------------------------------------------
# LLM backend (recommended for cloud deployments)
# -----------------------------------------------------------------------------
# If OPENAI_API_KEY is set, the app uses OpenAI.
# If unset, the app falls back to local Ollama.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Ollama fallback (local development)
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# Optional persistence (Supabase)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_anon_or_service_role_key

# -----------------------------------------------------------------------------
# App networking
# -----------------------------------------------------------------------------
# Shiny frontend -> FastAPI base URL (no trailing slash).
# In single-service mode, this can stay localhost/PORT default.
PCOSENSE_API_URL=http://127.0.0.1:8000

# Comma-separated browser origins for CORS (FastAPI).
# Set this to your deployed frontend origin(s).
# Example:
# CORS_ORIGINS=https://your-app.example.com,http://127.0.0.1:3838
CORS_ORIGINS=https://connect.systems-apps.com


# Platform runtime port (used by hosted environments like Render/Connect).
PORT=8000
